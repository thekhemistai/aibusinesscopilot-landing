    <meta name="description" content="Premium done-for-you AI systems for businesses and operators. From Claude setup to custom AI systems, we handle the build so you get the leverage.">
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>">
